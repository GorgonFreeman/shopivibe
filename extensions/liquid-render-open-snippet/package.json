{
  "name": "liquid-render-open-snippet",
  "displayName": "Liquid render → snippet",
  "description": "Highlights quoted snippet names in {% render '...' %} with a small link-out icon (visual only). Cmd+Click / F12 (Go to Definition) or the command opens snippets/*.liquid.",
  "version": "0.0.4",
  "publisher": "shopivibe",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:liquid",
    "onLanguage:liquid-html",
    "onCommand:shopivibe.liquid-render-open-snippet.openAtCursor",
    "workspaceContains:**/*.liquid"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shopivibe.liquid-render-open-snippet.openAtCursor",
        "title": "Open Liquid render snippet at cursor"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0"
  }
}
