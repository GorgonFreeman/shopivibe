<picture class="picture_renderer {{ classes }}">
  {% assign d_size = d_size | default: '2880x' %}
  {% assign t_size = t_size | default: '2000x' %}
  {% assign m_size = m_size | default: '1400x' %}
  {% assign xs_size = xs_size | default: '800x' %}

  <source media="(max-width: 400px)" srcset="{{ xs | default: m | default: t | default: d | img_url: xs_size }}">
  <source media="(max-width: 767px)" srcset="{{ m | default: t | default: d | img_url: m_size }}">
  <source media="(max-width: 991px)" srcset="{{ t | default: d | img_url: t_size }}">

  {% if d %}
    {%- if decorative -%}
      {%- assign image_alt = "" -%}
    {%- else -%}
      {%- assign image_alt = alt | default: d.alt | escape -%}
    {%- endif -%}
    <img 
      src="{{ d | img_url: d_size }}" 
      alt="{{ image_alt }}"
      {%- if decorative -%}role="presentation"{%- endif -%}
      {% if full_width %}style="width: 100%;"{% endif %}
      class="{{ img_classes }}"
      {{ img_attributes }}>
  {% else %}
    {{ 'image' | placeholder_svg_tag: 'w-100 placeholder-svg placeholder-svg--landscape' }}
  {% endif %}
</picture>
